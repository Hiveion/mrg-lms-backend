datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// User Roles
enum UserRole {
  ADMIN
  COORDINATOR
  TUTOR
  STUDENT
  PARENT
}

// Account Status
enum UserStatus {
  ACTIVE
  INACTIVE
  PENDING
  INCOMPLETE
}

// Tutor Application Status
enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum EnrollmentStatus {
  REQUESTED
  DEMO_SCHEDULED
  DEMO_COMPLETED
  ACTIVE
  INACTIVE
}

// Session Status
enum SessionStatus {
  SCHEDULED
  ONGOING
  COMPLETED
  CANCELLED
  RESCHEDULED
  PENDING
}

enum SessionType {
  REGULAR
  EXTRA
}

// Homework Enums
enum HomeworkType {
  QUIZ
  FILE
}

enum DeadlineType {
  FIXED_DATE
  RELATIVE
}

enum QuestionType {
  MCQ
  TRUE_FALSE
  SHORT
  FILE
}

enum SubmissionStatus {
  SUBMITTED
  LATE
  PENDING
  GRADED
}

enum WeekDay {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum DiscussionType {
  QUESTION
  ANNOUNCEMENT
  DISCUSSION
}

model User {
  id                   Int        @id @default(autoincrement()) @map("user_id")
  email                String     @unique
  googleId             String?    @unique @map("google_id")
  passwordHash         String?    @map("password_hash")
  firstName            String     @map("first_name")
  lastName             String     @map("last_name")
  profilePicture       String?    @map("profile_picture")
  phoneNumber          String?    @map("phone_number")
  createdAt            DateTime   @default(now()) @map("created_at")
  updatedAt            DateTime   @updatedAt @map("updated_at")
  status               UserStatus @default(INCOMPLETE)
  userType             UserRole?  @map("user_type")
  mustChangePassword   Boolean    @default(false) @map("must_change_password")
  invitationExpiresAt  DateTime?  @map("invitation_expires_at")
  resetPasswordToken   String?    @map("reset_password_token")
  resetPasswordExpires DateTime?  @map("reset_password_expires")
  googleAccessToken    String?    @map("google_access_token")
  googleRefreshToken   String?    @map("google_refresh_token")
  googleTokenExpiry    DateTime?  @map("google_token_expiry")

  // Relationships
  tutorProfile       Tutor?
  studentProfile     Student?
  parentProfile      Parent?
  coordinatorProfile Coordinator?
  ratingLikes        RatingLike[]
  ratings            Rating[]
  notifications      Notification[]
  discussionThreads  DiscussionThread[]
  discussionReplies  DiscussionReply[]
  discussionLikes    DiscussionLike[]
  replyLikes         ReplyLike[]

  @@map("users")
}

model Tutor {
  id                Int               @id @default(autoincrement()) @map("tutor_id")
  bio               String?
  qualifications    String[]
  applicationStatus ApplicationStatus @default(PENDING) @map("application_status")
  averageRating     Float             @default(0.0) @map("average_rating")
  totalReviews      Int               @default(0) @map("total_reviews")

  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId Int  @unique @map("user_id")

  classes          Class[]
  ratings          Rating[]
  availabilities   TutorAvailability[]
  sessionFeedbacks SessionFeedback[]

  @@map("tutors")
}

model Student {
  id             Int      @id @default(autoincrement()) @map("student_id")
  grade          String?
  rating         Float    @default(0.0)
  enrollmentDate DateTime @default(now()) @map("enrollment_date")

  user                User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId              Int                   @unique @map("user_id")
  parents             ParentStudent[]
  enrollments         Enrollment[]
  homeworkSubmissions HomeworkSubmission[]
  availabilities      StudentAvailability[]
  rescheduleRequests  RescheduleRequest[]
  sessionFeedbacks    SessionFeedback[]

  @@map("students")
}

model Parent {
  id               Int      @id @default(autoincrement()) @map("parent_id")
  occupation       String?
  numberOfChildren Int?     @default(0) @map("number_of_children")
  createdAt        DateTime @default(now()) @map("created_at")

  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId   Int             @unique @map("user_id")
  students ParentStudent[]

  @@map("parents")
}

model ParentStudent {
  id           Int      @id @default(autoincrement()) @map("parent_student_id")
  parentId     Int      @map("parent_id")
  studentId    Int      @map("student_id")
  relationship String // "Mother", "Father", "Guardian", etc.
  createdAt    DateTime @default(now()) @map("created_at")

  parent  Parent  @relation(fields: [parentId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([parentId, studentId])
  @@map("parent_students")
}

model Coordinator {
  id        Int      @id @default(autoincrement()) @map("coordinator_id")
  createdAt DateTime @default(now()) @map("created_at")

  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId Int  @unique @map("user_id")

  @@map("coordinators")
}

model Subject {
  id          Int      @id @default(autoincrement()) @map("subject_id")
  name        String   @unique
  description String?
  code        String?  @unique // e.g., "MATH101", "ENG201"
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  classes Class[]

  @@map("subjects")
}

model Class {
  id                  Int      @id @default(autoincrement()) @map("class_id")
  name                String   @map("class_name")
  subjectId           Int      @map("subject_id")
  tutorId             Int      @map("tutor_id")
  grade               String?
  isActive            Boolean  @default(true) @map("is_active")
  isDemo              Boolean  @default(true) @map("is_demo")
  frequency           Int      @default(1)
  currentStudentCount Int      @default(0) @map("current_student_count")
  maxStudentCount     Int?     @map("max_student_count")
  classFee            Float    @default(0.0) @map("class_fee")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  subject           Subject            @relation(fields: [subjectId], references: [id])
  tutor             Tutor              @relation(fields: [tutorId], references: [id])
  sessions          Session[]
  schedules         ClassSchedule[]
  enrollments       Enrollment[]
  homeworks         Homework[]
  discussionThreads DiscussionThread[]
  recordings        Recording[]

  @@map("classes")
}

model ClassSchedule {
  id        Int      @id @default(autoincrement()) @map("schedule_id")
  classId   Int      @map("class_id")
  day       WeekDay
  startTime String   @map("start_time") // HH:mm
  duration  Int // in minutes
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  class Class @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@map("class_schedules")
}

model Rating {
  id              Int      @id @default(autoincrement()) @map("rating_id")
  userId          Int      @map("user_id")
  tutorId         Int      @map("tutor_id")
  overallRating   Float    @map("overall_rating")
  teachingQuality Int      @map("teaching_quality")
  communication   Int      @map("communication")
  punctuality     Int      @map("punctuality")
  review          String?
  likes           Int      @default(0)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  tutor       Tutor        @relation(fields: [tutorId], references: [id], onDelete: Cascade)
  ratingLikes RatingLike[]

  @@unique([userId, tutorId])
  @@map("ratings")
}

model RatingLike {
  id       Int @id @default(autoincrement()) @map("rating_like_id")
  userId   Int @map("user_id")
  ratingId Int @map("review_id")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating Rating @relation(fields: [ratingId], references: [id], onDelete: Cascade)

  @@unique([userId, ratingId])
  @@map("rating_likes")
}

model Session {
  id                   Int           @id @default(autoincrement()) @map("session_id")
  classId              Int           @map("class_id")
  dateTime             DateTime      @map("date_time")
  duration             Int // in minutes
  status               SessionStatus @default(SCHEDULED)
  type                 SessionType   @default(REGULAR)
  rescheduledSessionId Int?          @map("rescheduled_session_id")
  cancellationReason   String?       @map("cancellation_reason")
  link                 String?
  extraClassRate       Float?        @map("extra_class_rate")
  googleEventId        String?       @map("google_event_id")
  createdAt            DateTime      @default(now()) @map("created_at")
  updatedAt            DateTime      @updatedAt @map("updated_at")

  class              Class               @relation(fields: [classId], references: [id], onDelete: Cascade)
  rescheduledSession Session?            @relation("RescheduledSession", fields: [rescheduledSessionId], references: [id])
  nextSessions       Session[]           @relation("RescheduledSession")
  rescheduleRequests RescheduleRequest[]
  recording          Recording?
  feedbacks          SessionFeedback[]

  @@map("sessions")
}

enum RecordingStatus {
  AVAILABLE
  EXPIRING_SOON
  EXPIRED
}

model Recording {
  id            Int             @id @default(autoincrement()) @map("recording_id")
  sessionId     Int             @unique @map("session_id")
  classId       Int             @map("class_id")
  videoUrl      String          @map("video_url")
  duration      String?
  fileSize      String?         @map("file_size")
  viewCount     Int             @default(0) @map("view_count")
  retentionDays Int             @default(14) @map("retention_days")
  status        RecordingStatus @default(AVAILABLE)
  expiresAt     DateTime        @map("expires_at")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  class   Class   @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@map("recordings")
}

model Enrollment {
  id               Int              @id @default(autoincrement()) @map("enrollment_id")
  studentId        Int              @map("student_id")
  classId          Int              @map("class_id")
  enrollmentDate   DateTime         @default(now()) @map("enrollment_date")
  assignedPrice    Float            @map("assigned_price")
  description      String?          @map("description")
  status           EnrollmentStatus @default(REQUESTED)
  confirmationDate DateTime?        @map("confirmation_date")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  class   Class   @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@unique([studentId, classId])
  @@map("enrollments")
}

model Homework {
  id           Int          @id @default(autoincrement()) @map("homework_id")
  classId      Int          @map("class_id")
  title        String
  description  String?
  type         HomeworkType @default(FILE)
  fileUrl      String?      @map("file_url")
  totalMarks   Float        @map("total_marks")
  deadlineType DeadlineType @default(FIXED_DATE) @map("deadline_type")
  deadlineDate DateTime?    @map("deadline_date")
  deadlineDays Int?         @map("deadline_days")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  class       Class                @relation(fields: [classId], references: [id], onDelete: Cascade)
  questions   HomeworkQuestion[]
  submissions HomeworkSubmission[]

  @@map("homeworks")
}

model HomeworkQuestion {
  id            Int          @id @default(autoincrement()) @map("question_id")
  homeworkId    Int          @map("homework_id")
  questionText  String       @map("question_text")
  questionType  QuestionType @map("question_type")
  marks         Float
  correctAnswer String?      @map("correct_answer")

  homework Homework           @relation(fields: [homeworkId], references: [id], onDelete: Cascade)
  answers  SubmissionAnswer[]

  @@map("homework_questions")
}

model HomeworkSubmission {
  id                Int              @id @default(autoincrement()) @map("submission_id")
  homeworkId        Int              @map("homework_id")
  studentId         Int              @map("student_id")
  submittedAt       DateTime         @default(now()) @map("submitted_at")
  status            SubmissionStatus @default(PENDING)
  totalMarksAwarded Float?           @map("total_marks_awarded")
  feedback          String?
  submissionFileUrl String?          @map("submission_file_url")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  homework Homework           @relation(fields: [homeworkId], references: [id], onDelete: Cascade)
  student  Student            @relation(fields: [studentId], references: [id], onDelete: Cascade)
  answers  SubmissionAnswer[]

  @@map("homework_submissions")
}

model SubmissionAnswer {
  id           Int     @id @default(autoincrement()) @map("answer_id")
  submissionId Int     @map("submission_id")
  questionId   Int     @map("question_id")
  answerText   String? @map("answer_text")
  marksAwarded Float?  @map("marks_awarded")

  submission HomeworkSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  question   HomeworkQuestion   @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("submission_answers")
}

model TutorAvailability {
  id        Int      @id @default(autoincrement()) @map("availability_id")
  tutorId   Int      @map("tutor_id")
  day       WeekDay
  startTime String   @map("start_time") // Using string for time like "14:00"
  endTime   String   @map("end_time") // Using string for time like "16:00"
  createdAt DateTime @default(now()) @map("created_at")

  tutor Tutor @relation(fields: [tutorId], references: [id], onDelete: Cascade)

  @@map("tutor_availabilities")
}

model StudentAvailability {
  id        Int      @id @default(autoincrement()) @map("availability_id")
  studentId Int      @map("student_id")
  day       WeekDay
  startTime String   @map("start_time")
  endTime   String   @map("end_time")
  createdAt DateTime @default(now()) @map("created_at")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("student_availabilities")
}

enum RescheduleStatus {
  PENDING
  ACCEPTED
  DECLINED
}

model RescheduleRequest {
  id               Int              @id @default(autoincrement()) @map("reschedule_id")
  sessionId        Int              @map("session_id")
  studentId        Int              @map("student_id")
  proposedDateTime DateTime         @map("proposed_date_time")
  reason           String?
  status           RescheduleStatus @default(PENDING)
  responseReason   String?          @map("response_reason")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("reschedule_requests")
}

enum NotificationType {
  ANNOUNCEMENT
  SYSTEM
  CLASS
  HOMEWORK
  PAYMENT
  ENROLLMENT
  RESCHEDULE
}

model Notification {
  id        Int              @id @default(autoincrement()) @map("notification_id")
  userId    Int              @map("user_id")
  title     String
  message   String
  type      NotificationType @default(SYSTEM)
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model DiscussionThread {
  id        Int            @id @default(autoincrement()) @map("thread_id")
  classId   Int            @map("class_id")
  type      DiscussionType @default(DISCUSSION)
  title     String
  body      String         @db.Text
  authorId  Int            @map("author_id")
  resolved  Boolean        @default(false)
  pinned    Boolean        @default(false)
  tags      String[]
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")

  class   Class             @relation(fields: [classId], references: [id], onDelete: Cascade)
  author  User              @relation(fields: [authorId], references: [id], onDelete: Cascade)
  replies DiscussionReply[]
  likes   DiscussionLike[]

  @@map("discussion_threads")
}

model DiscussionReply {
  id        Int      @id @default(autoincrement()) @map("reply_id")
  threadId  Int      @map("thread_id")
  authorId  Int      @map("author_id")
  content   String   @db.Text
  isAnswer  Boolean  @default(false) @map("is_answer")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  thread DiscussionThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author User             @relation(fields: [authorId], references: [id], onDelete: Cascade)
  likes  ReplyLike[]

  @@map("discussion_replies")
}

model DiscussionLike {
  id       Int @id @default(autoincrement()) @map("like_id")
  threadId Int @map("thread_id")
  userId   Int @map("user_id")

  thread DiscussionThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user   User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([threadId, userId])
  @@map("discussion_likes")
}

model ReplyLike {
  id      Int @id @default(autoincrement()) @map("like_id")
  replyId Int @map("reply_id")
  userId  Int @map("user_id")

  reply DiscussionReply @relation(fields: [replyId], references: [id], onDelete: Cascade)
  user  User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([replyId, userId])
  @@map("reply_likes")
}

model SessionFeedback {
  id        Int      @id @default(autoincrement()) @map("feedback_id")
  sessionId Int      @map("session_id")
  studentId Int      @map("student_id")
  tutorId   Int      @map("tutor_id")
  rating    Int
  note      String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  tutor   Tutor   @relation(fields: [tutorId], references: [id], onDelete: Cascade)

  @@unique([sessionId, studentId])
  @@map("session_feedbacks")
}
