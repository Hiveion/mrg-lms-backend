
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// User Roles
enum UserRole {
  ADMIN
  COORDINATOR
  TUTOR
  STUDENT
  PARENT
}

// Account Status
enum UserStatus {
  ACTIVE
  INACTIVE
  PENDING
  INCOMPLETE
}

// Tutor Application Status
enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
}
// Session Status
enum SessionStatus {
  SCHEDULED
  ONGOING
  COMPLETED
  CANCELLED
  RESCHEDULED
}

model User {
  id             Int        @id @default(autoincrement()) @map("user_id")
  email          String     @unique
  googleId       String?    @unique @map("google_id")
  passwordHash   String?    @map("password_hash")
  firstName      String     @map("first_name")
  lastName       String     @map("last_name")
  profilePicture String?    @map("profile_picture")
  phoneNumber    String?    @map("phone_number")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")
  status         UserStatus @default(INCOMPLETE)
  userType       UserRole?  @map("user_type")

  // Relationships
  tutorProfile       Tutor?
  studentProfile     Student?
  parentProfile      Parent?
  coordinatorProfile Coordinator?

  @@map("users")
}

model Tutor {
  id                Int               @id @default(autoincrement()) @map("tutor_id")
  bio               String?
  qualifications    String[]
  applicationStatus ApplicationStatus @default(PENDING) @map("application_status")
  averageRating     Float             @default(0.0) @map("average_rating")
  totalReviews      Int               @default(0) @map("total_reviews")

  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId Int  @unique @map("user_id")

  classes Class[]

  @@map("tutors")
}

model Student {
  id             Int             @id @default(autoincrement()) @map("student_id")
  grade          String?
  enrollmentDate DateTime        @default(now()) @map("enrollment_date")

  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId  Int             @unique @map("user_id")
  parents ParentStudent[]

  @@map("students")
}

model Parent {
  id               Int             @id @default(autoincrement()) @map("parent_id")
  occupation       String?
  numberOfChildren Int?            @default(0) @map("number_of_children")
  createdAt        DateTime        @default(now()) @map("created_at")

  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId   Int             @unique @map("user_id")
  students ParentStudent[]

  @@map("parents")
}

model ParentStudent {
  id           Int      @id @default(autoincrement()) @map("parent_student_id")
  parentId     Int      @map("parent_id")
  studentId    Int      @map("student_id")
  relationship String   // "Mother", "Father", "Guardian", etc.
  createdAt    DateTime @default(now()) @map("created_at")

  parent  Parent  @relation(fields: [parentId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([parentId, studentId])
  @@map("parent_students")
}

model Coordinator {
  id        Int       @id @default(autoincrement()) @map("coordinator_id")
  createdAt DateTime  @default(now()) @map("created_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId   Int       @unique @map("user_id")

  @@map("coordinators")
}

model Subject {
  id            Int          @id @default(autoincrement()) @map("subject_id")
  name          String       @unique
  description   String?
  code          String?      @unique // e.g., "MATH101", "ENG201"
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  classes Class[]

  @@map("subjects")
}

model Class {
  id                  Int      @id @default(autoincrement()) @map("class_id")
  name                String   @map("class_name")
  subjectId           Int      @map("subject_id")
  tutorId             Int      @map("tutor_id")
  grade               String?
  isActive            Boolean  @default(true) @map("is_active")
  isDemo              Boolean  @default(true) @map("is_demo")
  currentStudentCount Int      @default(0) @map("current_student_count")
  maxStudentCount     Int?     @map("max_student_count")
  classFee            Float    @default(0.0) @map("class_fee")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  subject  Subject   @relation(fields: [subjectId], references: [id])
  tutor    Tutor     @relation(fields: [tutorId], references: [id])
  sessions Session[]

  @@map("classes")
}

model Session {
  id                   Int           @id @default(autoincrement()) @map("session_id")
  classId              Int           @map("class_id")
  dateTime             DateTime      @map("date_time")
  duration             Int // in minutes
  status               SessionStatus @default(SCHEDULED)
  rescheduledSessionId Int?          @map("rescheduled_session_id")
  cancellationReason   String?       @map("cancellation_reason")
  link                 String?
  createdAt            DateTime      @default(now()) @map("created_at")
  updatedAt            DateTime      @updatedAt @map("updated_at")

  class              Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  rescheduledSession Session? @relation("RescheduledSession", fields: [rescheduledSessionId], references: [id])
  nextSessions       Session[] @relation("RescheduledSession")

  @@map("sessions")
}

