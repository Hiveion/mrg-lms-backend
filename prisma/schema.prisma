
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// User Roles
enum UserRole {
  ADMIN
  COORDINATOR
  TUTOR
  STUDENT
  PARENT
}

// Account Status
enum UserStatus {
  ACTIVE
  INACTIVE
  PENDING
  INCOMPLETE
}

// Tutor Application Status
enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum EnrollmentStatus {
  REQUESTED
  DEMO_SCHEDULED
  DEMO_COMPLETED
  ACTIVE
  INACTIVE
}
// Session Status
enum SessionStatus {
  SCHEDULED
  ONGOING
  COMPLETED
  CANCELLED
  RESCHEDULED
}

// Homework Enums
enum HomeworkType {
  QUIZ
  FILE
}

enum DeadlineType {
  FIXED_DATE
  RELATIVE
}

enum QuestionType {
  MCQ
  TRUE_FALSE
  SHORT
  FILE
}

enum SubmissionStatus {
  SUBMITTED
  LATE
  PENDING
  GRADED
}

model User {
  id             Int        @id @default(autoincrement()) @map("user_id")
  email          String     @unique
  googleId       String?    @unique @map("google_id")
  passwordHash   String?    @map("password_hash")
  firstName      String     @map("first_name")
  lastName       String     @map("last_name")
  profilePicture String?    @map("profile_picture")
  phoneNumber    String?    @map("phone_number")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")
  status         UserStatus @default(INCOMPLETE)
  userType       UserRole?  @map("user_type")

  // Relationships
  tutorProfile       Tutor?
  studentProfile     Student?
  parentProfile      Parent?
  coordinatorProfile Coordinator?
  ratingLikes        RatingLike[]
  ratings            Rating[]

  @@map("users")
}

model Tutor {
  id                Int               @id @default(autoincrement()) @map("tutor_id")
  bio               String?
  qualifications    String[]
  applicationStatus ApplicationStatus @default(PENDING) @map("application_status")
  averageRating     Float             @default(0.0) @map("average_rating")
  totalReviews      Int               @default(0) @map("total_reviews")

  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId Int  @unique @map("user_id")

  classes Class[]
  ratings Rating[]

  @@map("tutors")
}

model Student {
  id             Int             @id @default(autoincrement()) @map("student_id")
  grade          String?
  enrollmentDate DateTime        @default(now()) @map("enrollment_date")

  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId  Int             @unique @map("user_id")
  parents ParentStudent[]
  enrollments Enrollment[]
  homeworkSubmissions HomeworkSubmission[]

  @@map("students")
}

model Parent {
  id               Int             @id @default(autoincrement()) @map("parent_id")
  occupation       String?
  numberOfChildren Int?            @default(0) @map("number_of_children")
  createdAt        DateTime        @default(now()) @map("created_at")

  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId   Int             @unique @map("user_id")
  students ParentStudent[]

  @@map("parents")
}

model ParentStudent {
  id           Int      @id @default(autoincrement()) @map("parent_student_id")
  parentId     Int      @map("parent_id")
  studentId    Int      @map("student_id")
  relationship String   // "Mother", "Father", "Guardian", etc.
  createdAt    DateTime @default(now()) @map("created_at")

  parent  Parent  @relation(fields: [parentId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([parentId, studentId])
  @@map("parent_students")
}

model Coordinator {
  id        Int       @id @default(autoincrement()) @map("coordinator_id")
  createdAt DateTime  @default(now()) @map("created_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId   Int       @unique @map("user_id")

  @@map("coordinators")
}

model Subject {
  id            Int          @id @default(autoincrement()) @map("subject_id")
  name          String       @unique
  description   String?
  code          String?      @unique // e.g., "MATH101", "ENG201"
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  classes Class[]

  @@map("subjects")
}

model Class {
  id                  Int      @id @default(autoincrement()) @map("class_id")
  name                String   @map("class_name")
  subjectId           Int      @map("subject_id")
  tutorId             Int      @map("tutor_id")
  grade               String?
  isActive            Boolean  @default(true) @map("is_active")
  isDemo              Boolean  @default(true) @map("is_demo")
  currentStudentCount Int      @default(0) @map("current_student_count")
  maxStudentCount     Int?     @map("max_student_count")
  classFee            Float    @default(0.0) @map("class_fee")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  subject  Subject   @relation(fields: [subjectId], references: [id])
  tutor   Tutor     @relation(fields: [tutorId], references: [id])
  sessions Session[]
  enrollments Enrollment[]
  homeworks Homework[]

  @@map("classes")
}

model Rating {
  id              Int      @id @default(autoincrement()) @map("rating_id")
  userId          Int      @map("user_id")
  tutorId         Int      @map("tutor_id")
  overallRating   Float    @map("overall_rating")
  teachingQuality Int      @map("teaching_quality")
  communication   Int      @map("communication")
  punctuality     Int      @map("punctuality")
  review          String?
  likes           Int      @default(0)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  tutor           Tutor        @relation(fields: [tutorId], references: [id], onDelete: Cascade)
  ratingLikes     RatingLike[]

  @@unique([userId, tutorId])
  @@map("ratings")
}

model RatingLike {
  id       Int  @id @default(autoincrement()) @map("rating_like_id")
  userId   Int  @map("user_id")
  ratingId Int  @map("review_id")

  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating   Rating @relation(fields: [ratingId], references: [id], onDelete: Cascade)

  @@unique([userId, ratingId])
  @@map("rating_likes")
}

model Session {
  id                   Int           @id @default(autoincrement()) @map("session_id")
  classId              Int           @map("class_id")
  dateTime             DateTime      @map("date_time")
  duration             Int // in minutes
  status               SessionStatus @default(SCHEDULED)
  rescheduledSessionId Int?          @map("rescheduled_session_id")
  cancellationReason   String?       @map("cancellation_reason")
  link                 String?
  createdAt            DateTime      @default(now()) @map("created_at")
  updatedAt            DateTime      @updatedAt @map("updated_at")

  class              Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  rescheduledSession Session? @relation("RescheduledSession", fields: [rescheduledSessionId], references: [id])
  nextSessions       Session[] @relation("RescheduledSession")

  @@map("sessions")
}

model Enrollment {
  id               Int              @id @default(autoincrement()) @map("enrollment_id")
  studentId        Int              @map("student_id")
  classId          Int              @map("class_id")
  enrollmentDate   DateTime         @default(now()) @map("enrollment_date")
  assignedPrice    Float            @map("assigned_price")
  description      String?          @map("description")
  status           EnrollmentStatus @default(REQUESTED)
  confirmationDate DateTime?        @map("confirmation_date")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  class   Class   @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@unique([studentId, classId])
  @@map("enrollments")
}

model Homework {
  id           Int           @id @default(autoincrement()) @map("homework_id")
  classId      Int           @map("class_id")
  title        String
  description  String?
  type         HomeworkType  @default(FILE)
  fileUrl      String?       @map("file_url")
  totalMarks   Float         @map("total_marks")
  deadlineType DeadlineType  @default(FIXED_DATE) @map("deadline_type")
  deadlineDate DateTime?     @map("deadline_date")
  deadlineDays Int?          @map("deadline_days")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  class        Class         @relation(fields: [classId], references: [id], onDelete: Cascade)
  questions    HomeworkQuestion[]
  submissions  HomeworkSubmission[]

  @@map("homeworks")
}

model HomeworkQuestion {
  id            Int          @id @default(autoincrement()) @map("question_id")
  homeworkId    Int          @map("homework_id")
  questionText  String       @map("question_text")
  questionType  QuestionType @map("question_type")
  marks         Float
  correctAnswer String?      @map("correct_answer")

  homework      Homework     @relation(fields: [homeworkId], references: [id], onDelete: Cascade)
  answers       SubmissionAnswer[]

  @@map("homework_questions")
}

model HomeworkSubmission {
  id                Int              @id @default(autoincrement()) @map("submission_id")
  homeworkId        Int              @map("homework_id")
  studentId         Int              @map("student_id")
  submittedAt       DateTime         @default(now()) @map("submitted_at")
  status            SubmissionStatus @default(PENDING)
  totalMarksAwarded Float?           @map("total_marks_awarded")
  feedback          String?
  submissionFileUrl String?          @map("submission_file_url")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  homework          Homework         @relation(fields: [homeworkId], references: [id], onDelete: Cascade)
  student           Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  answers           SubmissionAnswer[]

  @@map("homework_submissions")
}

model SubmissionAnswer {
  id            Int                @id @default(autoincrement()) @map("answer_id")
  submissionId  Int                @map("submission_id")
  questionId    Int                @map("question_id")
  answerText    String?            @map("answer_text")
  marksAwarded  Float?             @map("marks_awarded")

  submission    HomeworkSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  question      HomeworkQuestion   @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("submission_answers")
}

